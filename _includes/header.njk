<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Lulu home">
      <span class="logo-frame logo-frame--header">
        <img class="brand-logo" src="/lulu-logo.svg" alt="" width="30" height="30">
      </span>
      <span class="site-title">Lulu</span>
    </a>
    <nav class="site-nav" aria-label="Main">
      <ul class="site-nav__list">
        <li>
          <a href="/privacy-policy/" class="site-nav__link"{% if navActive == "privacy" %} aria-current="page"{% endif %}>Privacy Policy</a>
        </li>
        <li>
          <a href="/terms/" class="site-nav__link"{% if navActive == "terms" %} aria-current="page"{% endif %}>Terms of Service</a>
        </li>
        <li>
          <a href="/support/" class="site-nav__link"{% if navActive == "support" %} aria-current="page"{% endif %}>Support</a>
        </li>
      </ul>
    </nav>
  </div>
</header>
