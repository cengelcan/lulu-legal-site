{% set pageLang = lang or "en" %}
{% set copy = home[pageLang] %}
<!DOCTYPE html>
<html lang="{{ pageLang }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ copy.title }}</title>
  <meta name="description" content="{{ copy.description }}">
  <meta name="theme-color" content="#A998D6">
  <link rel="canonical" href="{{ site.url }}{{ canonicalPath or ('/' + pageLang + '/') }}">
  <link rel="alternate" hreflang="en" href="{{ site.url }}/en/">
  <link rel="alternate" hreflang="de" href="{{ site.url }}/de/">
  <link rel="alternate" hreflang="tr" href="{{ site.url }}/tr/">
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}/">
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">

  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ canonicalPath or ('/' + pageLang + '/') }}">
  <meta property="og:title" content="{{ copy.title }}">
  <meta property="og:description" content="{{ copy.description }}">
  <meta property="og:image" content="{{ site.url }}{{ copy.screenshots.hero.src }}">
  <meta property="og:site_name" content="Lulu">

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ copy.title }}">
  <meta name="twitter:description" content="{{ copy.description }}">
  <meta name="twitter:image" content="{{ site.url }}{{ copy.screenshots.hero.src }}">

  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="landing">
  {% include "header.njk" %}
  <main>
    {{ content | safe }}
  </main>
  {% include "footer.njk" %}
</body>
</html>
